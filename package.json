{
  "name": "ngo-hospital-referral-tracker",
  "version": "1.0.0",
  "description": "Web-based feedback and referral tracking system for NGOs and hospitals.",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node --watch server/src/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "start": "node server/src/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test",
    "db:init": "node server/scripts/init-db.js",
    "db:reset": "node server/scripts/reset-db.js",
    "db:seed": "node server/scripts/seed-db.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "bcryptjs": "^3.0.2",
    "concurrently": "^10.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.541.0",
    "mysql2": "^3.14.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.18.0",
    "vite": "^8.0.16"
  }
}
